{
  "manifest_version": 3,
  "name": "MiTube",
  "version": "0.0.1",
  "description": "Enhance your YouTube playlist experience with duration tracking and end time prediction",
  "icons": {
    "16": "icons/icon16.png",
    "40": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"],
      "js": ["content/loader.js"],
      
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/*.js", "utils/*.js", "features/*.js"],
      "matches": ["https://www.youtube.com/*", "https://m.youtube.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MiTube - YouTube Playlist Enhancer"
  },
  "background": {
    "service_worker": "background.js"
  }
}